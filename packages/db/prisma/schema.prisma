generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// USERS & AUTH
// ============================================

model Member {
  id             String   @id @default(uuid()) @db.Uuid
  supabaseAuthId String   @unique @map("supabase_auth_id") @db.Uuid
  email          String   @unique
  firstName      String   @map("first_name")
  lastName       String   @map("last_name")
  avatarUrl      String?  @map("avatar_url")
  profession     String?
  bio            String?
  company        String?
  phone          String?
  linkedinUrl    String?  @map("linkedin_url")
  isAdmin        Boolean  @default(false) @map("is_admin")
  isActive       Boolean  @default(true) @map("is_active")
  joinedAt       DateTime @default(now()) @map("joined_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  messages                Message[]
  channelMemberships      ChannelMember[]
  conversationMemberships ConversationParticipant[]
  investments             MemberInvestment[]
  createdInvestments      Investment[]             @relation("InvestmentCreator")
  eventRegistrations      EventRegistration[]
  createdEvents           Event[]                  @relation("EventCreator")
  createdAlbums           Album[]
  uploadedPhotos          Photo[]
  invoices                Invoice[]
  givenRecommendations    Recommendation[]         @relation("RecommendationFrom")
  receivedRecommendations Recommendation[]         @relation("RecommendationTo")

  @@map("members")
}

// ============================================
// MESSAGING
// ============================================

enum ChannelCategory {
  le_cercle
  le_grand_salon
  thematiques
  aide

  @@map("channel_category")
}

model Channel {
  id          String          @id @default(uuid()) @db.Uuid
  name        String
  displayName String          @map("display_name")
  description String?
  category    ChannelCategory
  isReadOnly  Boolean         @default(false) @map("is_read_only")
  sortOrder   Int             @default(0) @map("sort_order")
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz

  messages Message[]
  members  ChannelMember[]

  @@map("channels")
}

model Message {
  id             String        @id @default(uuid()) @db.Uuid
  channelId      String?       @map("channel_id") @db.Uuid
  conversationId String?       @map("conversation_id") @db.Uuid
  authorId       String        @map("author_id") @db.Uuid
  content        String
  parentId       String?       @map("parent_id") @db.Uuid
  isEdited       Boolean       @default(false) @map("is_edited")
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  channel      Channel?      @relation(fields: [channelId], references: [id])
  conversation Conversation? @relation(fields: [conversationId], references: [id])
  author       Member        @relation(fields: [authorId], references: [id])
  parent       Message?      @relation("MessageThread", fields: [parentId], references: [id])
  replies      Message[]     @relation("MessageThread")

  @@index([channelId, createdAt(sort: Desc)])
  @@index([conversationId, createdAt(sort: Desc)])
  @@map("messages")
}

model Conversation {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  messages     Message[]
  participants ConversationParticipant[]

  @@map("conversations")
}

model ConversationParticipant {
  conversationId String    @map("conversation_id") @db.Uuid
  memberId       String    @map("member_id") @db.Uuid
  lastReadAt     DateTime? @map("last_read_at") @db.Timestamptz

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  member       Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@id([conversationId, memberId])
  @@map("conversation_participants")
}

model ChannelMember {
  channelId  String    @map("channel_id") @db.Uuid
  memberId   String    @map("member_id") @db.Uuid
  lastReadAt DateTime? @map("last_read_at") @db.Timestamptz

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  member  Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@id([channelId, memberId])
  @@map("channel_members")
}

// ============================================
// INVESTMENTS
// ============================================

enum DealStatus {
  draft
  open
  funding
  funded
  closed
  cancelled

  @@map("deal_status")
}

enum InterestStatus {
  interested
  committed
  invested
  withdrawn

  @@map("interest_status")
}

model Investment {
  id            String     @id @default(uuid()) @db.Uuid
  title         String
  description   String?
  location      String?
  targetAmount  Decimal?   @map("target_amount") @db.Decimal(12, 2)
  currentAmount Decimal    @default(0) @map("current_amount") @db.Decimal(12, 2)
  minimumTicket Decimal?   @map("minimum_ticket") @db.Decimal(12, 2)
  deckUrl       String?    @map("deck_url")
  coverImageUrl String?    @map("cover_image_url")
  status        DealStatus @default(draft)
  openDate      DateTime?  @map("open_date") @db.Timestamptz
  closeDate     DateTime?  @map("close_date") @db.Timestamptz
  createdById   String     @map("created_by") @db.Uuid
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  createdBy         Member             @relation("InvestmentCreator", fields: [createdById], references: [id])
  memberInvestments MemberInvestment[]

  @@map("investments")
}

model MemberInvestment {
  id           String         @id @default(uuid()) @db.Uuid
  investmentId String         @map("investment_id") @db.Uuid
  memberId     String         @map("member_id") @db.Uuid
  amount       Decimal?       @db.Decimal(12, 2)
  status       InterestStatus @default(interested)
  notes        String?
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  investment Investment @relation(fields: [investmentId], references: [id])
  member     Member     @relation(fields: [memberId], references: [id])

  @@unique([investmentId, memberId])
  @@map("member_investments")
}

// ============================================
// EVENTS
// ============================================

enum EventStatus {
  draft
  published
  sold_out
  past
  cancelled

  @@map("event_status")
}

model Event {
  id            String      @id @default(uuid()) @db.Uuid
  title         String
  description   String?
  location      String?
  address       String?
  startsAt      DateTime    @map("starts_at") @db.Timestamptz
  endsAt        DateTime?   @map("ends_at") @db.Timestamptz
  price         Decimal     @default(0) @db.Decimal(10, 2)
  maxAttendees  Int?        @map("max_attendees")
  coverImageUrl String?     @map("cover_image_url")
  status        EventStatus @default(draft)
  createdById   String      @map("created_by") @db.Uuid
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  createdBy     Member              @relation("EventCreator", fields: [createdById], references: [id])
  registrations EventRegistration[]
  albums        Album[]
  invoices      Invoice[]

  @@map("events")
}

model EventRegistration {
  id            String   @id @default(uuid()) @db.Uuid
  eventId       String   @map("event_id") @db.Uuid
  memberId      String   @map("member_id") @db.Uuid
  paymentId     String?  @map("payment_id")
  paymentStatus String   @default("pending") @map("payment_status")
  registeredAt  DateTime @default(now()) @map("registered_at") @db.Timestamptz

  event  Event  @relation(fields: [eventId], references: [id])
  member Member @relation(fields: [memberId], references: [id])

  @@unique([eventId, memberId])
  @@map("event_registrations")
}

// ============================================
// PHOTO GALLERY
// ============================================

model Album {
  id            String   @id @default(uuid()) @db.Uuid
  eventId       String?  @map("event_id") @db.Uuid
  title         String
  description   String?
  coverPhotoUrl String?  @map("cover_photo_url")
  createdById   String   @map("created_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  event     Event?  @relation(fields: [eventId], references: [id])
  createdBy Member  @relation(fields: [createdById], references: [id])
  photos    Photo[]

  @@map("albums")
}

model Photo {
  id            String   @id @default(uuid()) @db.Uuid
  albumId       String   @map("album_id") @db.Uuid
  storagePath   String   @map("storage_path")
  thumbnailPath String?  @map("thumbnail_path")
  caption       String?
  uploadedById  String   @map("uploaded_by") @db.Uuid
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  album      Album  @relation(fields: [albumId], references: [id], onDelete: Cascade)
  uploadedBy Member @relation(fields: [uploadedById], references: [id])

  @@map("photos")
}

// ============================================
// INVOICES
// ============================================

model Invoice {
  id            String    @id @default(uuid()) @db.Uuid
  invoiceNumber String    @unique @map("invoice_number")
  memberId      String    @map("member_id") @db.Uuid
  eventId       String?   @map("event_id") @db.Uuid
  amount        Decimal   @db.Decimal(10, 2)
  taxAmount     Decimal   @default(0) @map("tax_amount") @db.Decimal(10, 2)
  totalAmount   Decimal   @map("total_amount") @db.Decimal(10, 2)
  description   String?
  pdfUrl        String?   @map("pdf_url")
  paymentRef    String?   @map("payment_ref")
  issuedAt      DateTime  @default(now()) @map("issued_at") @db.Timestamptz
  paidAt        DateTime? @map("paid_at") @db.Timestamptz

  member Member @relation(fields: [memberId], references: [id])
  event  Event? @relation(fields: [eventId], references: [id])

  @@map("invoices")
}

// ============================================
// RECOMMENDATIONS
// ============================================

model Recommendation {
  id           String   @id @default(uuid()) @db.Uuid
  fromMemberId String   @map("from_member_id") @db.Uuid
  toMemberId   String   @map("to_member_id") @db.Uuid
  content      String
  isPublic     Boolean  @default(true) @map("is_public")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  fromMember Member @relation("RecommendationFrom", fields: [fromMemberId], references: [id])
  toMember   Member @relation("RecommendationTo", fields: [toMemberId], references: [id])

  @@unique([fromMemberId, toMemberId])
  @@map("recommendations")
}
