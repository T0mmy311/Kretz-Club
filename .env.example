# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Database (Supabase Postgres connection string)
DATABASE_URL=postgresql://postgres:xxx@db.xxx.supabase.co:5432/postgres

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Kretz Club

# Payment (Stripe) — required for paid event registrations.
# Leave at the PLACEHOLDER values to disable paid checkout (UI shows "Paiement non disponible").
STRIPE_SECRET_KEY=sk_test_PLACEHOLDER
STRIPE_WEBHOOK_SECRET=whsec_PLACEHOLDER
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_PLACEHOLDER

# Cron jobs (Vercel) — secret used to authenticate scheduled requests.
# Generate a long random string (e.g. `openssl rand -hex 32`) and set the same value
# in the Vercel project Environment Variables.
CRON_SECRET=PLACEHOLDER_GENERATE_RANDOM

# Resend (transactional emails) — leave unset to log emails instead of sending.
RESEND_API_KEY=

# Sentry error monitoring (PLACEHOLDER disables it; set real values to enable)
NEXT_PUBLIC_SENTRY_DSN=PLACEHOLDER
SENTRY_DSN=PLACEHOLDER
SENTRY_ORG=PLACEHOLDER
SENTRY_PROJECT=PLACEHOLDER
SENTRY_AUTH_TOKEN=PLACEHOLDER

# Mapbox (PLACEHOLDER disables the map view in /investissements; UI falls back to a notice card)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.PLACEHOLDER

# Anthropic (PLACEHOLDER disables AI channel summaries; UI shows "Service IA non configuré")
ANTHROPIC_API_KEY=PLACEHOLDER
